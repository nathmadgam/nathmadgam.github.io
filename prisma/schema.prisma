generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Inquiry {
  id        String        @id @default(cuid())
  name      String
  email     String
  discord   String?
  project   String
  budget    String?
  message   String
  status    InquiryStatus @default(NEW)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([status, createdAt])
}

enum InquiryStatus {
  NEW
  REVIEWING
  ACCEPTED
  DECLINED
}
